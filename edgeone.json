{
  "name": "expiry-ledger",
  "buildCommand": "echo skip build",
  "installCommand": "echo skip install",
  "outputDirectory": "dist",
  "nodeVersion": "22.11.0",
  "schedules": [
    {
      "name": "daily-expire-notify",
      "cron": "0 8 * * *",
      "timezone": "Asia/Shanghai",
      "path": "/api/notify/run",
      "method": "POST",
      "payload": {
        "from": "edgeone-schedule"
      }
    }
  ],
  "headers": [
    {
      "source": "/*",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
